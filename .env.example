# ===========================================
# ENVIRONMENT VARIABLES TEMPLATE
# ===========================================
# Copy this file to .env and replace placeholder values with actual credentials
# Never commit the actual .env file to version control

# ===========================================
# SUPABASE CONFIGURATION
# ===========================================
# Supabase project URL - found in your Supabase project settings
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key - found in your Supabase project settings > API
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key-here

# Supabase project ID - found in your Supabase project settings
VITE_SUPABASE_PROJECT_ID=your-project-id-here

# ===========================================
# EXTERNAL API KEYS
# ===========================================
# OpenAI API key - required for financial-ai-analyst and ocr-extract functions
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Google Cloud Vision API key - required for ocr-extract function
# Get your API key from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLOUD_VISION_API_KEY=your-google-cloud-vision-api-key-here

# ===========================================
# DEVELOPMENT SETTINGS
# ===========================================
# Environment mode (development, staging, production)
NODE_ENV=development

# Debug mode for additional logging
DEBUG=false

# ===========================================
# SECURITY NOTES
# ===========================================
# 1. Never commit this file or .env to version control
# 2. Use different API keys for different environments
# 3. Rotate API keys regularly
# 4. Use environment-specific .env files (.env.local, .env.production, etc.)
# 5. Consider using a secrets management service for production deployments
